# WordPress REST API Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# WordPress Site URL (e.g., https://638331.us26.myftpupload.com)
WORDPRESS_URL=https://638331.us26.myftpupload.com

# WordPress Admin Username
WORDPRESS_USERNAME=admin

# WordPress Application Password
# Retrieve from macOS Keychain:
# 1. Open Keychain Access
# 2. Search for "WordPress" or "claude"
# 3. Copy the password and paste below
WORDPRESS_PASSWORD=

# MCP Server Configuration
MCP_SERVER_NAME=wordpress-rest-api
